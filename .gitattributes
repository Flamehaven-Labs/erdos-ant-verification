# Enforce LF line endings for all text files (Windows-safe)
* text=auto eol=lf

# Python
*.py text eol=lf
*.pyi text eol=lf

# Config
*.toml text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.json text eol=lf
*.md text eol=lf
*.txt text eol=lf

# Shell
*.sh text eol=lf
*.ps1 text eol=crlf

# Binary
*.pdf binary
*.png binary
*.jpg binary
